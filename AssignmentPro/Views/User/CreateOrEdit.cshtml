@model AssignmentPro.Models.User

@{
    ViewData["Title"] = Model.UserID == null ? "Add New User" : "Edit User";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="CreateOrEdit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="UserID" />

   @*  <div class="mb-3">
        <label asp-for="UserID" class="form-label">User ID</label>
        <input asp-for="UserID" class="form-control" placeholder="Enter unique User ID" />
        <span asp-validation-for="UserID" class="text-danger"></span>
    </div> *@

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" placeholder="Full Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" placeholder="Email Address" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PasswordHash" class="form-label"> PasswordHash</label>
        <input asp-for="PasswordHash" class="form-control" placeholder="PasswordHash" />
    </div>

    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
    </div>

    <div class="mb-3">
        <label asp-for="PresentSalary" class="form-label">Present Salary</label>
        <input asp-for="PresentSalary" class="form-control" placeholder="0.00" />
    </div>

    <div class="mb-3">
        <label asp-for="Degree" class="form-label">Degree</label>
        <input asp-for="Degree" class="form-control" placeholder="Degree" />
    </div>

    <div class="mb-3">
        <label asp-for="University" class="form-label">University</label>
        <input asp-for="University" class="form-control" placeholder="University Name" />
    </div>

    <div class="mb-3">
        <label asp-for="CGPA" class="form-label">CGPA</label>
        <input asp-for="CGPA" class="form-control" placeholder="0.00" />
    </div>

    <div class="mb-3">
        <label asp-for="CompletionYear" class="form-label">Completion Year</label>
        <input asp-for="CompletionYear" class="form-control" placeholder="YYYY" />
    </div>

    <div class="mb-3">
        <label asp-for="ResumePath" class="form-label">Resume Path</label>
        <input asp-for="ResumePath" class="form-control" placeholder="Upload or enter resume path" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}