@{
    ViewData["Title"] = "Already Applied";
}

<style>
    body {
        background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
        font-family: 'Segoe UI', sans-serif;
        color: #fff;
    }

    .message-container {
        max-width: 600px;
        margin: 100px auto;
        padding: 40px;
        text-align: center;
        background: rgba(255,255,255,0.08);
        border-radius: 20px;
        backdrop-filter: blur(15px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    }

        .message-container h1 {
            font-size: 30px;
            margin-bottom: 20px;
            background: linear-gradient(45deg,#00f2fe,#4facfe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .message-container p {
            font-size: 18px;
            color: #fff;
        }

    .btn-home {
        display: inline-block;
        margin-top: 25px;
        padding: 10px 25px;
        border-radius: 10px;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        color: #000;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-home:hover {
            background: linear-gradient(45deg,#7367f0,#00f2fe);
            color: #fff;
        }
</style>

<div class="message-container">
    <h1>⚠ Already Applied</h1>
    <p>You have already applied for this job.</p>
    <a href="@Url.Action("Index", "Home")" class="btn-home">Go Back to Job List</a>
</div>
 
