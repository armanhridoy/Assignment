@model IEnumerable<AssignmentPro.Models.Job>

<style>
    body {
        margin: 0;
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        font-family: 'Segoe UI', sans-serif;
        color: #fff;
    }

    .page-title {
        text-align: center;
        padding: 30px 0 10px;
        font-size: 32px;
        font-weight: bold;
        color: #00f2fe;
        letter-spacing: 1px;
    }

    .container {
        max-width: 1200px;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 25px;
        padding: 20px;
    }

    .job-card {
        background: rgba(255, 255, 255, 0.07);
        border-radius: 20px;
        padding: 25px;
        backdrop-filter: blur(12px);
        transition: 0.4s;
        position: relative;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .job-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }

    .status {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        background: #00f2fe;
        color: #000;
    }
    .title {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 10px;
    }
    .desc {
        font-size: 14px;
        color: #ccc;
        margin-bottom: 15px;
        line-height: 1.5;
    }
    .meta {
        font-size: 13px;
        margin-bottom: 20px;
        color: #aaa;
        line-height: 1.6;
    }

    .btn {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 12px;
        background: linear-gradient(45deg, #00f2fe, #4facfe);
        color: #000;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn:hover {
            background: linear-gradient(45deg, #7367f0, #00f2fe);
            color: #fff;
        }
    .no-jobs {
        text-align: center;
        font-size: 18px;
        color: #ccc;
        margin-top: 50px;
    }
</style>

<h2 class="page-title">🚀 Job Opportunities</h2>

<div class="container">

    @if (!Model.Any())
    {
        <div class="no-jobs">No jobs available right now.</div>
    }
    else
    {
        @foreach (var job in Model)
        {
            <div class="job-card">

                <div class="status">@job.Status</div>

                <div class="title">@job.JobTitle</div>

                <div class="desc">
                    @(job.Description?.Length > 100
                                ? job.Description.Substring(0, 100) + "..."
                                : job.Description)
        </div>

                <div class="meta">
                    💰 @job.SalaryRange <br />
                    📅 Deadline: @(job.Deadline?.ToString("dd MMM yyyy") ?? "N/A") <br />
                    🕒 Posted: @job.CreatedAt.ToString("dd MMM yyyy")
                </div>

        @if (job.Status == "Active")
                {
                    <a href="/home/Details/@job.JobID" class="btn">View Details</a>
                }

            </div>
        }
    }

</div>