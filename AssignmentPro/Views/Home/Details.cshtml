@model AssignmentPro.Models.Job

<style>
    body {
        background: #0f172a;
        color: #fff;
        font-family: 'Segoe UI';
    }

    .container {
        max-width: 800px;
        margin: 50px auto;
    }

    .card {
        background: rgba(255,255,255,0.05);
        padding: 30px;
        border-radius: 20px;
        backdrop-filter: blur(10px);
    }

    .title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .meta {
        color: #aaa;
        margin-bottom: 20px;
    }

    .btn {
        padding: 12px 20px;
        border-radius: 10px;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        color: #000;
        font-weight: bold;
        text-decoration: none;
    }
</style>

<div class="container">
    <div class="card">

        <div class="title">@Model.JobTitle</div>

        <div class="meta">
            💰 @Model.SalaryRange <br />
            📅 Deadline: @(Model.Deadline?.ToString("dd MMM yyyy") ?? "N/A") <br />
            🕒 Posted: @Model.CreatedAt.ToString("dd MMM yyyy")
        </div>

        <p>@Model.Description</p>

        @if (!User.IsInRole("Administrator"))
        {

            <a asp-controller="Home" asp-action="Apply" asp-route-jobId="@Model.Id" class="btn">
                Apply Now
        </a>
        }

    </div>
</div>

