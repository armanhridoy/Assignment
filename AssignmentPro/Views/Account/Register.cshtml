@using AssignmentPro.Models.Auth
@model RegisterViewModel

<style>
    body {
        background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
        font-family: 'Segoe UI', sans-serif;
        color: #fff;
        margin: 0;
        padding: 0;
    }

    .form-container {
        max-width: 900px;
        margin: 40px auto;
        background: rgba(255,255,255,0.06);
        padding: 40px;
        border-radius: 25px;
        backdrop-filter: blur(15px);
        box-shadow: 0 25px 60px rgba(0,0,0,0.6);
        transition: 0.4s;
    }

    .title {
        text-align: center;
        font-size: 32px;
        margin-bottom: 30px;
        font-weight: bold;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-group {
        position: relative;
        margin-bottom: 20px;
    }

    .form-control {
        width: 100%;
        background: rgba(255,255,255,0.1);
        border: none;
        color: #fff;
        padding: 12px 15px 12px 40px;
        border-radius: 12px;
        transition: 0.3s;
    }

        .form-control::placeholder {
            color: #bbb;
        }

        .form-control:focus {
            border: 1px solid #00f2fe;
            box-shadow: 0 0 10px #00f2fe50;
            background: rgba(255,255,255,0.15);
        }

    .form-icon {
        position: absolute;
        top: 38px;
        left: 12px;
        color: #00f2fe;
        font-size: 14px;
    }

    label {
        font-size: 14px;
        margin-bottom: 5px;
        display: block;
    }

    .btn-submit {
        margin-top: 25px;
        width: 100%;
        padding: 14px;
        border-radius: 15px;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        border: none;
        font-weight: bold;
        color: #000;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background: linear-gradient(45deg,#7367f0,#00f2fe);
            color: #fff;
        }

    .footer-text {
        text-align: center;
        margin-top: 15px;
        font-size: 14px;
        color: #ccc;
    }

        .footer-text a {
            color: #00f2fe;
            text-decoration: none;
        }

    /* 🔥 RESPONSIVE PART */

    /* Tablet */
    @@media (max-width: 992px) {
        .form-container

    {
        margin: 20px;
        padding: 30px;
    }

    .title {
        font-size: 28px;
    }

    }

    /* Mobile */
    @@media (max-width: 768px) {
        .form-container

    {
        padding: 25px;
        border-radius: 20px;
    }

    .title {
        font-size: 24px;
    }

    .row > div {
        width: 100%;
    }

    .form-icon {
        top: 36px;
    }

    }

    /* Small Mobile */
    @@media (max-width: 480px) {
        .form-container

    {
        padding: 20px;
    }

    .title {
        font-size: 22px;
    }

    .btn-submit {
        padding: 12px;
        font-size: 14px;
    }

    }
</style>

<div class="form-container">

    <div class="title">🚀 Create Your Account</div>

    <form asp-action="Register" method="post">

        <div class="row">

            <div class="col-md-6 form-group">
                <label>Full Name</label>
                <i class="form-icon">👤</i>
                <input asp-for="Name" class="form-control" placeholder="Enter your name" />
            </div>

            <div class="col-md-6 form-group">
                <label>Email</label>
                <i class="form-icon">📧</i>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
            </div>

            <div class="col-md-6 form-group">
                <label>Password</label>
                <i class="form-icon">🔒</i>
                <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter password" />
            </div>

            <div class="col-md-6 form-group">
                <label>Phone</label>
                <i class="form-icon">📱</i>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Phone number" />
            </div>

        </div>

        <button type="submit" class="btn-submit">Create Account</button>

        <div class="footer-text">
            Already have an account? <a href="/Account/Login">Login</a>
        </div>

    </form>

</div>