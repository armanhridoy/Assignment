@using AssignmentPro.Models.Auth
@model RegisterViewModel
<style>
    body {
        background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
        font-family: 'Segoe UI';
        color: #fff;
    }

    .form-container {
        max-width: 900px;
        margin: 40px auto;
        background: rgba(255,255,255,0.05);
        padding: 30px;
        border-radius: 20px;
        backdrop-filter: blur(12px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .title {
        text-align: center;
        font-size: 28px;
        margin-bottom: 25px;
        font-weight: bold;
        color: #00f2fe;
    }

    .form-control {
        background: rgba(255,255,255,0.08);
        border: none;
        color: #fff;
    }

        .form-control::placeholder {
            color: #ccc;
        }

        .form-control:focus {
            box-shadow: none;
            border: 1px solid #00f2fe;
        }

    label {
        margin-top: 10px;
        font-size: 14px;
    }

    .btn-submit {
        margin-top: 20px;
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        border: none;
        font-weight: bold;
        color: #000;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background: linear-gradient(45deg,#7367f0,#00f2fe);
            color: #fff;
        }
</style>

<div class="form-container">

    <div class="title">🚀 Create Your Account</div>

    <form asp-action="Register" method="post" enctype="multipart/form-data">

        <div class="row">

            <!-- Name -->
            <div class="col-md-6">
                <label>Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter your name" />
            </div>

            <!-- Email -->
            <div class="col-md-6">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
            </div>

            <!-- Password -->
            <div class="col-md-6">
                <label>Password</label>
                <input type="password" name="Password" class="form-control" placeholder="Enter password" />
            </div>

            <!-- Phone -->
            <div class="col-md-6">
                <label>Phone</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Phone number" />
            </div>

            <!-- Salary -->
            <div class="col-md-6">
                <label>Present Salary</label>
                <input asp-for="PresentSalary" class="form-control" placeholder="e.g. 30000" />
            </div>

            <!-- Degree -->
            <div class="col-md-6">
                <label>Degree</label>
                <input asp-for="Degree" class="form-control" placeholder="BSc / MSc" />
            </div>

            <!-- University -->
            <div class="col-md-6">
                <label>University</label>
                <input asp-for="University" class="form-control" placeholder="Your university" />
            </div>

            <!-- CGPA -->
            <div class="col-md-6">
                <label>CGPA</label>
                <input asp-for="CGPA" class="form-control" placeholder="e.g. 3.50" />
            </div>

            <!-- Completion Year -->
            <div class="col-md-6">
                <label>Completion Year</label>
                <input asp-for="CompletionYear" class="form-control" placeholder="2024" />
            </div>

            <!-- Resume Upload -->
            <div class="col-md-6">
                <label>Upload Resume (PDF)</label>
                <input type="file" name="ResumeFile" class="form-control" accept="application/pdf" />
            </div>

        </div>

        <button type="submit" class="btn-submit">Create Account</button>

    </form>

</div>

