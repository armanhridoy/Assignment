@model AssignmentPro.Models.Auth.RegisterViewModel
@{
    Layout = null;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    :root {
        --primary-teal: #007c89;
        --primary-teal-dark: #006471;
        --primary-teal-light: rgba(0, 124, 137, 0.12);
        --text-dark: #2d3748;
        --text-muted: #718096;
        --border-light: #cbd5e1;
    }

    body {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        min-height: 100vh;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .register-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 2.5rem 1rem;
    }

    .register-card {
        background: #ffffff;
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 38px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .register-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        }

    .register-header {
        background: linear-gradient(135deg, var(--primary-teal), var(--primary-teal-dark));
        padding: 2.75rem 2rem;
        text-align: center;
        color: white;
        position: relative;
    }

        .register-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.18) 0%, transparent 60%);
            pointer-events: none;
        }

        .register-header h2 {
            font-weight: 700;
            font-size: 2.1rem;
            margin-bottom: 0.5rem;
        }

        .register-header p {
            opacity: 0.92;
            font-size: 1rem;
            margin: 0;
        }

    .register-body {
        padding: 2.5rem 2.25rem;
    }

    .form-label {
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 0.6rem;
        font-size: 0.95rem;
    }

    .input-group-custom {
        position: relative;
        margin-bottom: 1.9rem;
    }

    .form-control-custom {
        padding: 0.82rem 1rem 0.82rem 3.1rem;
        border: 1px solid var(--border-light);
        border-radius: 10px;
        font-size: 0.97rem;
        transition: all 0.25s ease;
        background: #fdfefe;
    }

        .form-control-custom:focus {
            border-color: var(--primary-teal);
            box-shadow: 0 0 0 4px var(--primary-teal-light);
            background: white;
        }

        .form-control-custom::placeholder {
            color: #a0aec0;
        }

    .input-icon {
        position: absolute;
        left: 1.1rem;
        top: 70%;
        transform: translateY(-50%);
        color: var(--primary-teal);
        font-size: 1.15rem;
        pointer-events: none;
    }

    /* --CHeck-- */

    .input-icon-o{
        position: absolute;
        left: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--primary-teal);
        font-size: 1.15rem;
        pointer-events: none;
    }

    .password-toggle {
        position: absolute;
        right: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 1.1rem;
        cursor: pointer;
        padding: 0.4rem;
        transition: color 0.2s;
    }

        .password-toggle:hover {
            color: var(--primary-teal);
        }

    .password-strength {
        margin-top: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .strength-meter {
        height: 5px;
        background: #e2e8f0;
        border-radius: 3px;
        overflow: hidden;
    }

    .strength-fill {
        height: 100%;
        width: 0%;
        transition: width 0.4s ease, background-color 0.4s ease;
    }

    .strength-text {
        font-size: 0.82rem;
        color: var(--text-muted);
        text-align: right;
    }

    .btn-register {
        background: linear-gradient(135deg, var(--primary-teal), var(--primary-teal-dark));
        border: none;
        padding: 0.9rem 1.5rem;
        font-weight: 600;
        font-size: 1.02rem;
        border-radius: 10px;
        color: white;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 0.8rem;
    }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 124, 137, 0.28);
        }

    .login-link {
        text-align: center;
        margin-top: 1.8rem;
        color: var(--text-muted);
        font-size: 0.95rem;
    }

        .login-link a {
            color: var(--primary-teal);
            font-weight: 600;
            text-decoration: none;
        }

            .login-link a:hover {
                color: var(--primary-teal-dark);
                text-decoration: underline;
            }

    .validation-feedback {
        font-size: 0.86rem;
        margin-top: 0.35rem;
        color: #e53e3e;
        display: block;
    }

    @@media (max-width: 576px) {
        .register-body, .register-header

    {
        padding-left: 1.6rem;
        padding-right: 1.6rem;
    }

    .register-header h2 {
        font-size: 1.85rem;
    }

    }
</style>

<div class="register-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="register-card">
                    <div class="register-header">
                        <h2>Create Account</h2>
                        <p>Join AssignmentPro and start your journey</p>
                    </div>

                    <div class="register-body">
                        <form asp-controller="Account" asp-action="Register" method="post" novalidate>
                            <!-- Full Name -->
                            <div class="input-group-custom">
                                <label asp-for="FullName" class="form-label">Full Name</label>
                                <span class="input-icon"><i class="bi bi-person-fill"></i></span>
                                <input asp-for="FullName" class="form-control form-control-custom" placeholder="Your full name" required />
                                <span asp-validation-for="FullName" class="validation-feedback"></span>
                            </div>

                            <!-- Email -->
                            <div class="input-group-custom">
                                <label asp-for="Email" class="form-label">Email Address</label>
                                <span class="input-icon"><i class="bi bi-envelope-fill"></i></span>
                                <input asp-for="Email" type="email" class="form-control form-control-custom" placeholder="you@example.com" required />
                                <span asp-validation-for="Email" class="validation-feedback"></span>
                            </div>

                            <!-- Phone -->
                            <div class="input-group-custom">
                                <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                                <span class="input-icon"><i class="bi bi-telephone-fill"></i></span>
                                <input asp-for="PhoneNumber" class="form-control form-control-custom" placeholder="+880 1X XXX XXXX" />
                                <span asp-validation-for="PhoneNumber" class="validation-feedback"></span>
                            </div>

                            <!-- Password -->
                            <div class="input-group-custom">
                                <label asp-for="Password" class="form-label">Password</label>
                                <span class="input-icon-o"><i class="bi bi-lock-fill"></i></span> @* //Check *@
                                <input asp-for="Password" type="password" id="password" class="form-control form-control-custom"
                                       placeholder="Minimum 8 characters" minlength="8" required />
                                <button type="button" class="password-toggle" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <div class="password-strength">
                                    <div class="strength-meter">
                                        <div class="strength-fill" id="strengthFill"></div>
                                    </div>
                                    <div class="strength-text" id="strengthText">Password strength</div>
                                </div>
                                <span asp-validation-for="Password" class="validation-feedback" id="passwordFeedback"></span>
                            </div>

                            <!-- Confirm Password -->
                            <div class="input-group-custom">
                                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                                <span class="input-icon"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="ConfirmPassword" type="password" class="form-control form-control-custom"
                                       placeholder="Confirm password" required />
                                <span asp-validation-for="ConfirmPassword" class="validation-feedback" id="confirmFeedback"></span>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-register">
                                    <i class="bi bi-person-plus me-2"></i> Create Account
                                </button>
                            </div>

                            <div class="login-link">
                                Already have an account? <a asp-controller="Account" asp-action="Login">Sign In</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Password visibility toggle
    document.getElementById('togglePassword')?.addEventListener('click', function () {
        const password = document.getElementById('password');
        const icon = this.querySelector('i');
        if (password.type === 'password') {
            password.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            password.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    });

    // Password strength & match checking
    const passwordInput = document.getElementById('password');
    const confirmInput = document.querySelector('input[asp-for="ConfirmPassword"]');
    const strengthFill = document.getElementById('strengthFill');
    const strengthText = document.getElementById('strengthText');
    const confirmFeedback = document.getElementById('confirmFeedback');

    function updateStrength() {
        const val = passwordInput.value;
        let score = 0;

        if (val.length >= 8) score += 25;
        if (/[A-Z]/.test(val)) score += 25;
        if (/[0-9]/.test(val)) score += 25;
        if (/[^A-Za-z0-9]/.test(val)) score += 25;

        strengthFill.style.width = score + '%';

        if (score <= 25) {
            strengthFill.style.background = '#dc3545';
            strengthText.textContent = 'Weak';
        } else if (score <= 50) {
            strengthFill.style.background = '#fd7e14';
            strengthText.textContent = 'Fair';
        } else if (score <= 75) {
            strengthFill.style.background = '#ffc107';
            strengthText.textContent = 'Good';
        } else {
            strengthFill.style.background = '#28a745';
            strengthText.textContent = 'Strong';
        }

        // Check password match
        if (confirmInput.value) {
            if (confirmInput.value !== val) {
                confirmFeedback.textContent = "Passwords do not match";
            } else {
                confirmFeedback.textContent = "";
            }
        }
    }

    passwordInput?.addEventListener('input', updateStrength);
    confirmInput?.addEventListener('input', updateStrength);
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}