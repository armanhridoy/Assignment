@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssignmentPro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #0f172a;
            color: #fff;
        }

        /* Navbar */
        .navbar {
            background: rgba(255,255,255,0.05) !important;
            backdrop-filter: blur(10px);
        }

        .navbar-brand {
            font-weight: bold;
            color: #00f2fe !important;
        }

        /* Footer */
        footer {
            background: #020617;
            color: #aaa;
            text-align: center;
            padding: 20px 0;
            margin-top: 50px;
        }

        footer a {
            color: #00f2fe;
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

<header>
    <nav class="navbar navbar-expand-sm navbar-dark shadow-sm mb-3">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🚀 AssignmentPro
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">

                <ul class="navbar-nav align-items-center gap-2">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item text-white me-2">
                            👋 Hello, <strong>@User.Identity.Name</strong>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-danger px-3">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-info px-4"
                               asp-controller="Account" asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-info px-4 text-dark"
                               asp-controller="Account" asp-action="Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer>
    <div class="container">
        <p>© 2026 AssignmentPro 🚀 | Built with ASP.NET Core</p>
        <p>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a> |
            <a href="#">Terms</a>
        </p>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)

</body>
</html>

