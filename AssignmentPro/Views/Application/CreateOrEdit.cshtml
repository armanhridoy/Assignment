@model AssignmentPro.Models.Application

@{
    var isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Application" : "Apply for Job";
}

<style>
    body {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        font-family: 'Segoe UI', sans-serif;
        color: #e2e8f0;
    }

    .apply-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 20px;
        border-radius: 16px;
        background: #111827;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 25px;
        color: #38bdf8;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        background: #020617;
        color: #fff;
        margin-bottom: 15px;
    }

        .form-control:focus {
            border: 1px solid #38bdf8;
            box-shadow: 0 0 6px #38bdf855;
        }

    .btn-submit {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: none;
        background: #38bdf8;
        color: #000;
        font-weight: bold;
        transition: 0.3s;
        margin-top: 10px;
    }

        .btn-submit:hover {
            background: #0ea5e9;
            color: #fff;
        }

    .file-preview {
        margin-top: 10px;
        font-size: 13px;
        color: #94a3b8;
    }

    /* Tabs */
    .nav-tabs .nav-link.active {
        background: #0f172a;
        border-color: #38bdf8 #38bdf8 #111827;
        color: #38bdf8;
    }

    .nav-tabs .nav-link {
        color: #94a3b8;
    }

    .modal-content {
        background: #0f172a;
        color: #e2e8f0;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .modal-header {
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .modal-title {
        color: #38bdf8;
    }

    .btn-close {
        filter: invert(1);
    }
</style>

<div class="apply-container">
    <div class="title">
        @(isEdit ? "✏ Edit Application" : "📄 Apply for Job")
    </div>

    <form asp-controller="Application"
          asp-action="@(isEdit ? "CreateOrEdit" : "ApplyJob")"
          method="post"
          enctype="multipart/form-data">

        <!-- Hidden Fields -->
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="JobId" />
        <input type="hidden" asp-for="ApplicationId" />

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-3" id="appTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info"
                        type="button" role="tab">
                    Applicant Information
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="resume-tab" data-bs-toggle="tab" data-bs-target="#resume"
                        type="button" role="tab">
                    Resume Upload
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Other Info Tab -->
            <div class="tab-pane fade show active" id="info" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <label>Full Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>Present Salary</label>
                        <input asp-for="PresentSalary" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>Expected Salary</label>
                        <input asp-for="ExpectionSalary" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>Degree</label>
                        <input asp-for="Degree" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>University</label>
                        <input asp-for="University" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>CGPA</label>
                        <input asp-for="CGPA" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>Completion Year</label>
                        <input asp-for="CompletionYear" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- Resume Tab -->
            <div class="tab-pane fade" id="resume" role="tabpanel">
                <div class="form-group">
                    <label>Upload Resume</label>
                    <input type="file" name="ResumeFile" class="form-control" />

                    @if (isEdit && !string.IsNullOrEmpty(Model.ResumePath))
                    {
                        <div class="file-preview">
                            📎 Current File:
                            <a href="javascript:void(0);"
                               onclick="openResumeModal('/Cv/@Model.ResumePath')"
                               style="color:#38bdf8;">
                                View Resume
                            </a>
                        </div>
                    }
                    <button type="submit" class="btn-submit">
                        @(isEdit ? "💾 Update Application" : "🚀 Submit Application")
                    </button>
                </div>
            </div>
        </div>

        

    </form>
</div>

<!-- Resume Modal -->
<div class="modal fade" id="resumeModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">📄 Resume Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="height:80vh;">
                <iframe id="resumeFrame" src="" width="100%" height="100%" style="border:none;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openResumeModal(filePath) {
            document.getElementById("resumeFrame").src = filePath;
            var modal = new bootstrap.Modal(document.getElementById('resumeModal'));
            modal.show();
        }
    </script>
} *@



@model AssignmentPro.Models.Application

@{
    var isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Application" : "Apply for Job";
}

<style>
    /* Body & Background */
    body {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        font-family: 'Segoe UI', sans-serif;
        color: #e0e7ff;
        margin: 0;
        padding: 0;
    }

    /* Main container */
    .apply-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 30px;
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.95);
        box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.1);
    }

    /* Title */
    .title {
        text-align: center;
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 30px;
        background: linear-gradient(45deg, #38bdf8, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Form Inputs */
    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.2);
        background: #1e293b;
        color: #f1f5f9;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 8px rgba(56, 223, 248, 0.5);
            background: #273449;
            outline: none;
        }

    /* Submit Button */
    .btn-submit {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #38bdf8, #0ea5e9);
        color: #000;
        font-weight: 700;
        font-size: 16px;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

        .btn-submit:hover {
            background: linear-gradient(135deg, #0ea5e9, #3b82f6);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.4);
        }

    /* File preview */
    .file-preview {
        margin-top: 10px;
        font-size: 14px;
        color: #60a5fa;
    }

    /* Tabs Styling */
    .nav-tabs {
        border-bottom: 2px solid rgba(255,255,255,0.2);
        margin-bottom: 25px;
    }

        .nav-tabs .nav-link {
            color: #94a3b8;
            border-radius: 10px 10px 0 0;
            margin-right: 5px;
            transition: 0.3s;
        }

            .nav-tabs .nav-link.active {
                background: linear-gradient(135deg, #38bdf8, #60a5fa);
                color: #000;
                border-color: #38bdf8 #38bdf8 #111827;
                font-weight: 600;
            }

    .tab-pane {
        padding-top: 10px;
    }

    /* Modal Styling */
    .modal-content {
        background: #1e293b;
        color: #e0e7ff;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .modal-header {
        border-bottom: 1px solid rgba(255,255,255,0.2);
    }

    .modal-title {
        color: #38bdf8;
        font-weight: 600;
    }

    .btn-close {
        filter: invert(1);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .apply-container

    {
        margin: 20px;
        padding: 20px;
    }

    }
</style>

<div class="apply-container">
    <div class="title">
        @(isEdit ? "✏ Edit Application" : "📄 Apply for Job")
    </div>

    <form asp-controller="Application"
          asp-action="@(isEdit ? "CreateOrEdit" : "ApplyJob")"
          method="post"
          enctype="multipart/form-data">

        <!-- Hidden Fields -->
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="JobId" />
        <input type="hidden" asp-for="ApplicationId" />

        <!-- Tabs -->
