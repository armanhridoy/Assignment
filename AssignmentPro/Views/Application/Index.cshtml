@model IEnumerable<AssignmentPro.Models.Application>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

 <style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
        color: #fff;
    }

    .container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 20px;
    }

    .title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 20px;
        color: #00f2fe;
        text-align: center;
    }

    /* Table for Desktop */
    .table-wrapper {
        display: block;
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: rgba(255,255,255,0.05);
        border-radius: 12px;
        overflow: hidden;
    }

    th, td {
        padding: 12px 15px;
        font-size: 14px;
        text-align: left;
    }

    th {
        background: rgba(255,255,255,0.1);
        color: #00f2fe;
    }

    tr:nth-child(even) {
        background: rgba(255,255,255,0.03);
    }

    .btn {
        padding: 6px 12px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        font-size: 12px;
        color: #000;
        background: linear-gradient(45deg,#00f2fe,#4facfe);
        transition: 0.3s;
        margin-right: 5px;
    }

        .btn:hover {
            background: linear-gradient(45deg,#7367f0,#00f2fe);
            color: #fff;
        }

    .btn-edit {
        background: linear-gradient(45deg,#f9a825,#ffeb3b);
    }

        .btn-edit:hover {
            background: linear-gradient(45deg,#ffeb3b,#f9a825);
            color: #000;
        }

    /* Cards for Mobile */
    .card {
        display: none;
        background: rgba(255,255,255,0.06);
        padding: 20px;
        border-radius: 15px;
        margin-bottom: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

        .card div {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .card .card-buttons {
            margin-top: 10px;
        }

    /* Responsive for Mobile */
    @@media (max-width: 768px) {
        .table-wrapper {
            display: none;
        }

        .card {
            display: block;
        }
    }

    /* Resume Modal */
    #resumeModal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

        #resumeModal .modal-content {
            position: relative;
            width: 80%;
            max-width: 800px;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
        }

        #resumeModal iframe {
            width: 100%;
            height: 600px;
            border: none;
        }

    #closeResumeModal {
        position: absolute;
        top: 10px;
        right: 15px;
        cursor: pointer;
        font-size: 22px;
        font-weight: bold;
    }
</style> 

<div class="container">
    <div class="title">📄 Applications List</div>

    @if (Model.Any())
    {
        <div class="table-wrapper">
            <table id="applicationTable">
                <thead>
                    <tr>
                        <th>App ID</th>
                        <th>Name</th>
                        <th>Job ID</th>
                        <th>Expected Salary</th>
                        <th>CGPA</th>
                        <th>Resume</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td>@app.ApplicationId</td>
                            <td>@app.Name</td>
                            <td>@app.JobId</td>
                            <td>@(app.ExpectionSalary ?? 0)</td>
                            <td>@(app.CGPA ?? 0)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(app.ResumePath))
                                {
                                    <a href="javascript:void(0);" class="btn" onclick="openResumeModal('/Cv/@app.ResumePath')">View</a>
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </td>
                            <td>
                                <a href="/Application/Details/@app.ApplicationId" class="btn">Details</a>
                                <a asp-action="CreateOrEdit"
                                   asp-route-id="@app.ApplicationId"
                                   class="btn btn-edit">✏ Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p>No applications found.</p>
    }
</div>

<!-- Resume Modal -->
<div id="resumeModal">
    <div class="modal-content">
        <span id="closeResumeModal">&times;</span>
        <iframe id="resumeFrame" src=""></iframe>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#applicationTable').DataTable({
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                stripeClasses: ['table-light', 'table-secondary'],
                columnDefs: [
                    { targets: 0, className: 'fw-bold text-primary' },
                    { targets: 2, className: 'text-success' },
                    { targets: 3, className: 'text-danger' }
                ],
                responsive: true
            });
        });

        function openResumeModal(path) {
            $('#resumeFrame').attr('src', path);
            $('#resumeModal').css('display', 'flex');
        }

        $('#closeResumeModal').click(function() {
            $('#resumeModal').hide();
            $('#resumeFrame').attr('src', '');
        });

        $('#resumeModal').click(function(e) {
            if(e.target.id === 'resumeModal') {
                $(this).hide();
                $('#resumeFrame').attr('src', '');
            }
        });
    </script>
}

